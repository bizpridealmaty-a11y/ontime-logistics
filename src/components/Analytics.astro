---
// Analytics component — Google Analytics 4 + Yandex.Metrika
// Injected into <head> from Layout.astro. Production-only.
//
// How to add Yandex.Metrika later: set YM_COUNTER_ID below to the real
// 8-digit counter number (e.g. 98765432) and uncomment the block.

const GA_MEASUREMENT_ID = 'G-T31WWZGK7S';
const YM_COUNTER_ID: number | null = null; // Paste Yandex.Metrika counter id here

// Analytics only runs on the production domain.
// Prevents local dev and preview deploys from polluting real counters.
const isProd = Astro.url.hostname === 'ontimeservice.kz';
---
{isProd && GA_MEASUREMENT_ID && (
  <>
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID, {
        anonymize_ip: true,
        send_page_view: true
      });
    </script>
  </>
)}

{isProd && YM_COUNTER_ID && (
  <>
    <link rel="preconnect" href="https://mc.yandex.ru" crossorigin />
    <script is:inline define:vars={{ YM_COUNTER_ID }}>
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

      ym(YM_COUNTER_ID, "init", {
        clickmap:true,
        trackLinks:true,
        accurateTrackBounce:true,
        webvisor:true,
        ecommerce:"dataLayer"
      });
    </script>
    <noscript>
      <div><img src={`https://mc.yandex.ru/watch/${YM_COUNTER_ID}`} style="position:absolute;left:-9999px;" alt="" /></div>
    </noscript>
  </>
)}

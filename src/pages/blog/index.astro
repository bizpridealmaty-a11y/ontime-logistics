---
import Layout from '../../layouts/Layout.astro';
import { BLOG_POSTS, unsUrl, unsSrcset } from '../../data/blog.js';
import { IC, ARR } from '../../data/icons.js';

const SITE_PHONE = '+7 775 242 77 44';
const SITE_URL = 'https://ontimeservice.kz';
const sorted = [...BLOG_POSTS].sort((a, b) => new Date(b.date) - new Date(a.date));

const blogIndexSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Главная", "item": `${SITE_URL}/`},
        {"@type": "ListItem", "position": 2, "name": "Блог", "item": `${SITE_URL}/blog`}
      ]
    },
    {
      "@type": "Blog",
      "name": "Блог On Time Service",
      "url": `${SITE_URL}/blog`,
      "description": "Экспертные статьи о грузоперевозках по Казахстану, негабарите, логистике из Китая, выборе перевозчика.",
      "publisher": {"@id": `${SITE_URL}/#organization`},
      "inLanguage": "ru-KZ",
      "blogPost": sorted.slice(0, 10).map(p => ({
        "@type": "BlogPosting",
        "headline": p.title,
        "url": `${SITE_URL}/blog/${p.slug}`,
        "datePublished": p.date,
        "description": p.excerpt
      }))
    }
  ]
};
---
<Layout
  title="Блог о грузоперевозках — On Time Service Алматы | Советы, маршруты, логистика"
  description={`Блог транспортной компании On Time Service. Статьи о грузоперевозках по Казахстану, негабарите, логистике из Китая, выборе перевозчика. Тел: ${SITE_PHONE}`}
  canonical="/blog"
  schema={blogIndexSchema}
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><span class="current">Блог</span>
</div>
<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">Экспертные материалы</span></div>
  <h1 class="title anim-2">Блог</h1>
  <p class="desc anim-3" style="max-width:600px;">Статьи о грузоперевозках, логистике и транспортном рынке Казахстана от экспертов On Time Service.</p>
</div>

<section class="sec">
  <!-- Featured post -->
  {sorted[0] && (
    <a class="card card-link fade" href={`/blog/${sorted[0].slug}`} style="display:grid;grid-template-columns:1fr 1fr;gap:0;margin-bottom:32px;overflow:hidden;padding:0;">
      <div style="overflow:hidden;">
        <img
          src={unsUrl(sorted[0].imgId, 800)}
          srcset={unsSrcset(sorted[0].imgId, [400, 640, 800, 1200])}
          sizes="(max-width:900px) 100vw, 50vw"
          alt={sorted[0].altHero}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="800" height="450"
          style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;"
        />
      </div>
      <div style="padding:32px;display:flex;flex-direction:column;justify-content:center;">
        <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
          <span style="background:var(--gold);color:#000;font-size:10px;font-weight:700;padding:3px 8px;border-radius:3px;text-transform:uppercase;letter-spacing:.06em;">{sorted[0].cat}</span>
          <span style="color:var(--gray);font-size:12px;">{sorted[0].dateDisplay}</span>
          <span style="color:var(--gray);font-size:12px;">{sorted[0].readTime}</span>
        </div>
        <h2 style="color:var(--light);font-size:1.4rem;margin-bottom:12px;line-height:1.3;">{sorted[0].title}</h2>
        <p class="desc" style="margin-bottom:20px;font-size:14px;">{sorted[0].excerpt}</p>
        <div class="btn btn-outline" style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;font-size:12px;width:fit-content;">
          Читать статью <Fragment set:html={ARR} />
        </div>
      </div>
    </a>
  )}

  <!-- Grid of remaining posts -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
    {sorted.slice(1).map(post => (
      <a class="card card-link fade" href={`/blog/${post.slug}`} style="padding:0;overflow:hidden;display:flex;flex-direction:column;">
        <div style="overflow:hidden;height:180px;">
          <img
            src={unsUrl(post.imgId, 480, 65)}
            srcset={unsSrcset(post.imgId, [320, 480, 640, 800], 65)}
            sizes="(max-width:520px) 100vw, (max-width:900px) 50vw, 33vw"
            alt={post.altHero}
            loading="lazy"
            decoding="async"
            width="480" height="270"
            style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;"
          />
        </div>
        <div style="padding:20px;flex:1;display:flex;flex-direction:column;">
          <div style="display:flex;gap:8px;margin-bottom:10px;align-items:center;flex-wrap:wrap;">
            <span style="background:rgba(201,168,76,.15);color:var(--gold);font-size:10px;font-weight:600;padding:2px 8px;border-radius:3px;">{post.cat}</span>
            <span style="color:var(--gray);font-size:11px;">{post.readTime}</span>
          </div>
          <h3 style="color:var(--light);font-size:1rem;line-height:1.4;margin-bottom:10px;flex:1;">{post.title}</h3>
          <div style="color:var(--gray);font-size:12px;">{post.dateDisplay}</div>
        </div>
      </a>
    ))}
  </div>
</section>

</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { SERVICE_REGIONS } from '../../data/service-regions.js';
import { IC, ARR } from '../../data/icons.js';

export function getStaticPaths() {
  return SERVICE_REGIONS.map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const SITE_PHONE = '+7 775 242 77 44';
const SITE_URL = 'https://ontimeservice.kz';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Главная", "item": `${SITE_URL}/`},
        {"@type": "ListItem", "position": 2, "name": "Услуги по регионам", "item": `${SITE_URL}/uslugi-region`},
        {"@type": "ListItem", "position": 3, "name": `${item.serviceTitle} — ${item.region}`, "item": `${SITE_URL}/uslugi-region/${item.slug}`}
      ]
    },
    {
      "@type": "Service",
      "name": `${item.serviceTitle} ${item.region}`,
      "description": item.descSeo,
      "url": `${SITE_URL}/uslugi-region/${item.slug}`,
      "provider": {"@id": `${SITE_URL}/#organization`},
      "areaServed": {"@type": "City", "name": item.region},
      "serviceType": item.serviceTitle
    },
    {
      "@type": "FAQPage",
      "mainEntity": item.faq.map(it => ({
        "@type": "Question",
        "name": it.q,
        "acceptedAnswer": {"@type": "Answer", "text": it.a}
      }))
    }
  ]
};
---
<Layout
  title={item.titleSeo}
  description={item.descSeo}
  canonical={`/uslugi-region/${item.slug}`}
  schema={schema}
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><a href="/uslugi">Услуги</a><span class="sep"> / </span><span class="current">{item.serviceTitle} {item.regionPrep}</span>
</div>

<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">{item.serviceShort} · {item.region}</span></div>
  <h1 class="title anim-2">{item.h1}</h1>
  <p class="desc anim-3" style="max-width:680px;">{item.intro}</p>
  <div class="anim-4" style="margin-top:24px;display:flex;gap:14px;flex-wrap:wrap;">
    <a class="btn btn-gold" href="/kontakty"><Fragment set:html={ARR} /> Рассчитать стоимость</a>
    <a class="btn btn-outline" href={`tel:${SITE_PHONE.replace(/\s/g,'')}`}>Позвонить {SITE_PHONE}</a>
  </div>
</div>

<!-- Что перевозим -->
<section class="sec">
  <div class="two-col">
    <div class="fade">
      <div class="sec-label"><div class="sec-label-line"></div><span class="sec-label-text">Что перевозим</span></div>
      <h2 class="title" style="margin-bottom:24px;">Типы грузов</h2>
      <p class="desc" style="line-height:1.85;margin-bottom:16px;">{item.cargoTypes}</p>
    </div>
    <div class="fade" style="display:flex;align-items:center;justify-content:center;">
      <div class="card" style="text-align:center;padding:48px 32px;width:100%;max-width:300px;">
        <div class="card-icon" style="margin:0 auto 18px;color:var(--gold);">
          <Fragment set:html={IC[item.iconKey]} />
        </div>
        <div class="card-title" style="margin-bottom:8px;font-size:18px;">{item.serviceTitle}</div>
        <div class="card-desc" style="margin-bottom:18px;">{item.region}</div>
        <a class="btn btn-gold" href="/kontakty" style="width:100%;justify-content:center;">Заявка</a>
      </div>
    </div>
  </div>
</section>

<!-- Маршруты -->
<section class="sec" style="background:var(--dark2);">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Направления</span></div>
  <h2 class="title fade" style="margin-bottom:32px;">Ключевые маршруты</h2>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;max-width:1100px;">
    {item.routes.map((r, i) => (
      <div class="card fade" style="display:flex;gap:18px;align-items:flex-start;">
        <div style="width:36px;height:36px;border-radius:50%;background:var(--gold-d);color:var(--gold);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;">{i + 1}</div>
        <div class="card-desc" style="font-size:14px;line-height:1.65;">{r}</div>
      </div>
    ))}
  </div>
</section>

<!-- Транспорт -->
<section class="sec">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Подходящий транспорт</span></div>
  <h2 class="title fade" style="margin-bottom:24px;">Какие машины используем</h2>
  <div style="display:flex;gap:12px;flex-wrap:wrap;">
    {item.transport.map(t => (
      <div class="tag" style="font-size:13px;padding:12px 20px;border:1px solid var(--border);color:var(--text);background:var(--dark3);">{t}</div>
    ))}
  </div>
</section>

<!-- Разрешения и документы -->
<section class="sec" style="background:var(--dark2);">
  <div class="container" style="max-width:900px;margin:0 auto;">
    <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Документы</span></div>
    <h2 class="title fade" style="margin-bottom:24px;">Разрешения и оформление</h2>
    <p class="desc fade" style="line-height:1.85;margin-bottom:16px;">{item.permits}</p>
    <div class="quote-block fade" style="margin-top:24px;">
      <div class="quote-label">Гарантия</div>
      <div class="quote-text" style="font-style:normal;">Все необходимые разрешения и сертификаты получаем сами. Клиенту — только подписание договора и приёмка груза.</div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="sec">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Вопросы и ответы</span></div>
  <h2 class="title fade" style="margin-bottom:32px;">Частые вопросы</h2>
  <div style="display:flex;flex-direction:column;gap:12px;max-width:900px;">
    {item.faq.map(({q,a}) => (
      <details class="card fade" style="cursor:pointer;padding:0;overflow:hidden;">
        <summary style="padding:20px 24px;font-size:15px;font-weight:600;color:var(--text);list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;">
          <span>{q}</span>
          <span style="color:var(--gold);font-size:20px;flex-shrink:0;">+</span>
        </summary>
        <div style="padding:0 24px 20px;color:var(--text2);font-size:14px;line-height:1.7;">{a}</div>
      </details>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="sec" style="background:var(--dark2);text-align:center;">
  <div class="fade">
    <div class="sec-label" style="justify-content:center;"><div class="sec-label-line"></div><span class="sec-label-text">Готовы заказать?</span><div class="sec-label-line"></div></div>
    <h2 class="title" style="margin-bottom:16px;">{item.serviceTitle} — {item.regionPrep}</h2>
    <p class="desc" style="max-width:520px;margin:0 auto 28px;">Менеджер свяжется в течение 30 минут — обсудим задачу, рассчитаем точную стоимость, согласуем график.</p>
    <a class="btn btn-gold" href="/kontakty" style="font-size:13px;padding:16px 40px;"><Fragment set:html={ARR} /> Оставить заявку</a>
  </div>
</section>

</Layout>

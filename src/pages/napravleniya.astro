---
import Layout from '../layouts/Layout.astro';
import { IC, ARR } from '../data/icons.js';

const SITE_PHONE = '+7 775 242 77 44';

const directions = [
  { from:'Алматы', to:'Астана', km:'1280 км', time:'14-16 ч', freq:'Ежедневно' },
  { from:'Алматы', to:'Шымкент', km:'690 км', time:'7-8 ч', freq:'Ежедневно' },
  { from:'Алматы', to:'Карагандa', km:'1270 км', time:'13-15 ч', freq:'3 раза/нед.' },
  { from:'Алматы', to:'Атырау', km:'2500 км', time:'26-30 ч', freq:'2 раза/нед.' },
  { from:'Алматы', to:'Актау', km:'3300 км', time:'36-40 ч', freq:'По заявке' },
  { from:'Алматы', to:'Костанай', km:'2100 км', time:'22-24 ч', freq:'2 раза/нед.' },
  { from:'Алматы', to:'Павлодар', km:'1560 км', time:'16-18 ч', freq:'2 раза/нед.' },
  { from:'Алматы', to:'Москва', km:'4600 км', time:'4-5 дней', freq:'По заявке' },
  { from:'Алматы', to:'Новосибирск', km:'2000 км', time:'2-3 дня', freq:'По заявке' },
  { from:'Алматы', to:'Бишкек', km:'250 км', time:'3-4 ч', freq:'Ежедневно' },
  { from:'Алматы', to:'Ташкент', km:'1100 км', time:'12-14 ч', freq:'2 раза/нед.' },
  { from:'Китай (Хоргос)', to:'Алматы', km:'350 км', time:'6-8 ч', freq:'Ежедневно' },
];
---
<Layout
  title="Направления грузоперевозок — On Time Service Алматы | Все маршруты"
  description={`Грузоперевозки по всем направлениям из Алматы. Казахстан, Россия, Китай, СНГ. ✓ 20 лет опыта. ✓ Расчёт за 30 мин. Тел: ${SITE_PHONE}`}
  canonical="/napravleniya"
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><span class="current">Направления</span>
</div>
<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">Маршруты перевозок</span></div>
  <h1 class="title anim-2">Направления</h1>
  <p class="desc anim-3" style="max-width:600px;">Регулярные рейсы по всем основным направлениям из Алматы. Казахстан, Россия, Китай и страны СНГ.</p>
</div>

<section class="sec">
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:14px;">
      <thead>
        <tr style="border-bottom:1px solid var(--border);">
          <th style="text-align:left;padding:12px 16px;color:var(--gold);font-weight:600;">Откуда</th>
          <th style="text-align:left;padding:12px 16px;color:var(--gold);font-weight:600;">Куда</th>
          <th style="text-align:left;padding:12px 16px;color:var(--gold);font-weight:600;">Расстояние</th>
          <th style="text-align:left;padding:12px 16px;color:var(--gold);font-weight:600;">Время в пути</th>
          <th style="text-align:left;padding:12px 16px;color:var(--gold);font-weight:600;">Частота</th>
          <th style="text-align:left;padding:12px 16px;color:var(--gold);font-weight:600;"></th>
        </tr>
      </thead>
      <tbody>
        {directions.map((d, i) => (
          <tr style={`border-bottom:1px solid var(--border);${i % 2 === 0 ? 'background:rgba(255,255,255,.02);' : ''}`} class="fade">
            <td style="padding:14px 16px;color:var(--light);">{d.from}</td>
            <td style="padding:14px 16px;color:var(--light);font-weight:500;">{d.to}</td>
            <td style="padding:14px 16px;color:var(--gray);">{d.km}</td>
            <td style="padding:14px 16px;color:var(--gray);">{d.time}</td>
            <td style="padding:14px 16px;color:var(--gold);font-size:12px;">{d.freq}</td>
            <td style="padding:14px 16px;">
              <a class="btn btn-outline" href="/kontakty" style="padding:6px 14px;font-size:11px;">Заказать</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- CTA -->
<section class="sec" style="background:var(--dark2);text-align:center;">
  <div class="fade">
    <div class="sec-label" style="justify-content:center;"><div class="sec-label-line"></div><span class="sec-label-text">Нет вашего направления?</span><div class="sec-label-line"></div></div>
    <h2 class="title" style="margin-bottom:16px;">Организуем любой маршрут</h2>
    <p class="desc" style="max-width:500px;margin:0 auto 28px;">Свяжитесь с нами — рассчитаем индивидуальный маршрут и стоимость доставки в течение 30 минут</p>
    <a class="btn btn-gold" href="/kontakty" style="font-size:13px;padding:16px 40px;"><Fragment set:html={ARR} /> Оставить заявку</a>
  </div>
</section>

</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { CASES } from '../../data/cases.js';
import { ARR } from '../../data/icons.js';

const SITE_PHONE = '+7 775 242 77 44';
const SITE_URL = 'https://ontimeservice.kz';

const keysyIndexSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Главная", "item": `${SITE_URL}/`},
    {"@type": "ListItem", "position": 2, "name": "Кейсы", "item": `${SITE_URL}/keysy`}
  ]
};
---
<Layout
  title="Кейсы перевозок — On Time Service | Реальные истории доставки"
  description={`Реальные кейсы грузоперевозок On Time Service. Алматы — Москва, Гуанчжоу — Астана, Новороссийск — Шымкент. Задача, решение, результат. Тел: ${SITE_PHONE}`}
  canonical="/keysy"
  schema={keysyIndexSchema}
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><span class="current">Кейсы</span>
</div>

<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">Реальные истории</span></div>
  <h1 class="title anim-2">Кейсы<br>перевозок</h1>
  <p class="desc anim-3" style="max-width:640px;">Истории реальных доставок: что было нужно клиенту, как мы это сделали и какой результат получили. Открыто и без приукрашивания.</p>
</div>

<section class="sec">
  <div style="display:flex;flex-direction:column;gap:24px;">
    {CASES.map(c => (
      <a class="card card-link fade" href={`/keysy/${c.slug}`} style="padding:32px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:24px;flex-wrap:wrap;margin-bottom:18px;">
          <div>
            <div class="tag" style="margin-bottom:12px;">{c.industry}</div>
            <div class="card-title" style="font-size:22px;line-height:1.3;margin-bottom:8px;">{c.route}</div>
            <div class="card-desc" style="margin-bottom:0;">{c.cargoType}</div>
          </div>
          <div style="text-align:right;flex-shrink:0;">
            <div style="font-family:Bebas Neue,sans-serif;font-size:32px;color:var(--gold);letter-spacing:2px;line-height:1;">{c.weight}</div>
            <div style="font-size:11px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-top:4px;">{c.duration}</div>
          </div>
        </div>
        <p class="card-desc" style="margin-bottom:14px;">{c.cardTeaser}</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          {c.metrics.map(m => (
            <div class="route-tag">{m.label}: {m.value}</div>
          ))}
        </div>
      </a>
    ))}
  </div>
</section>

<section class="sec" style="background:var(--dark2);text-align:center;">
  <div class="fade">
    <div class="sec-label" style="justify-content:center;"><div class="sec-label-line"></div><span class="sec-label-text">Ваш кейс будет следующим</span><div class="sec-label-line"></div></div>
    <h2 class="title" style="margin-bottom:16px;">Нужна доставка?</h2>
    <p class="desc" style="max-width:540px;margin:0 auto 28px;">Расскажите задачу — предложим решение и точную цену в течение 30 минут.</p>
    <a class="btn btn-gold" href="/kontakty" style="font-size:13px;padding:16px 40px;"><Fragment set:html={ARR} /> Оставить заявку</a>
  </div>
</section>

</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { IC, ARR } from '../../data/icons.js';

const SITE_PHONE = '+7 775 242 77 44';
---
<Layout
  title="Услуги грузоперевозок — On Time Service Алматы | Все виды транспорта"
  description={`Полный спектр транспортно-логистических услуг. Автоперевозки FTL/LTL, негабарит, трал, сборные грузы, доставка из Китая. ✓ 20 лет опыта. ✓ Все регионы Казахстана. Тел: ${SITE_PHONE}`}
  canonical="/uslugi"
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><span class="current">Услуги</span>
</div>
<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">Транспортная логистика</span></div>
  <h2 class="title anim-2">Наши услуги</h2>
  <p class="desc anim-3" style="max-width:600px;">Полный спектр транспортно-логистических услуг по Казахстану, России, Китаю и СНГ. Грузы от 100 кг до 70 тонн - любой сложности.</p>
</div>
<section class="sec">
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
    {[
      [IC.truck,'Автоперевозки','Грузовые автомобильные перевозки по всем направлениям. Собственный и привлечённый транспорт, все типы кузовов.','/uslugi/avtoperevozki'],
      [IC.oversize,'Негабаритные грузы','Перевозка нестандартных, крупногабаритных и тяжёлых грузов. Специализированный транспорт и разрешительная документация.','/uslugi/negabarit'],
      [IC.lowboy,'Перевозка тралом','Тяжёлая и строительная техника, нестандартные металлоконструкции. Трал, спецтехника, сопровождение.','/uslugi/tral'],
      [IC.box,'Сборные грузы','Консолидация грузов от нескольких отправителей в одну машину. Экономия на перевозке до 60%.','/uslugi/sbornyy-gruz'],
      [IC.city,'Доставка по Алматы','Срочная городская доставка по Алматы. Быстро, точно, с подтверждением.','/uslugi/dostavka-po-gorodu'],
      [IC.map,'По Казахстану','Межгородские перевозки по всем регионам Республики Казахстан. 12 регионов.','/uslugi/po-kazakhstanu'],
      [IC.globe,'Россия и СНГ','Международные перевозки в Россию и страны СНГ. Таможенное оформление и сопровождение.','/uslugi/rossiya-sng'],
      [IC.ship,'Из Китая','Импортная логистика из Китая в Казахстан. Получение, таможня, доставка до дверей.','/uslugi/kitay'],
      [IC.warehouse,'От 100 кг до 70 т','Малотоннажные и крупные грузы - любой объём. Оптимальная упаковка и крепление.','#'],
    ].map(([icon,title,desc,path]) => (
      <div class="card card-link fade" style="cursor:pointer;">
        <div class="card-icon"><Fragment set:html={icon} /></div>
        <div class="card-title" style="margin-bottom:10px;">{title}</div>
        <div class="card-desc">{desc}</div>
        {path !== '#' && (
          <div style="margin-top:16px;">
            <a class="btn btn-outline" href={path} style="padding:8px 16px;font-size:10px;">Подробнее <Fragment set:html={ARR} /></a>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

</Layout>

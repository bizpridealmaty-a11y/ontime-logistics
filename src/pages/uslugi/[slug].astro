---
import Layout from '../../layouts/Layout.astro';
import { SERVICES } from '../../data/services.js';
import { IC, ARR } from '../../data/icons.js';

export function getStaticPaths() {
  return SERVICES.map(service => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const SITE_PHONE = '+7 775 242 77 44';
const SITE_URL = 'https://ontimeservice.kz';

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Главная", "item": `${SITE_URL}/`},
        {"@type": "ListItem", "position": 2, "name": "Услуги", "item": `${SITE_URL}/uslugi`},
        {"@type": "ListItem", "position": 3, "name": service.title, "item": `${SITE_URL}/uslugi/${service.slug}`}
      ]
    },
    {
      "@type": "Service",
      "name": service.title,
      "description": service.descSeo,
      "url": `${SITE_URL}/uslugi/${service.slug}`,
      "provider": {"@id": `${SITE_URL}/#organization`},
      "areaServed": [
        {"@type": "Country", "name": "Казахстан"},
        {"@type": "City", "name": "Алматы"},
        {"@type": "City", "name": "Астана"}
      ],
      "serviceType": service.title,
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": service.title,
        "itemListElement": (service.features || []).map(f => ({
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": f.title,
            "description": f.desc
          }
        }))
      }
    }
  ]
};
---
<Layout
  title={service.titleSeo}
  description={service.descSeo}
  canonical={`/uslugi/${service.slug}`}
  schema={serviceSchema}
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><a href="/uslugi">Услуги</a><span class="sep"> / </span><span class="current">{service.title}</span>
</div>

<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">{service.tag}</span></div>
  <h1 class="title anim-2">{service.title}</h1>
  <p class="desc anim-3" style="max-width:640px;">{service.subtitle}</p>
  <div class="anim-4" style="margin-top:24px;">
    <a class="btn btn-gold" href="/kontakty"><Fragment set:html={ARR} /> Рассчитать стоимость</a>
  </div>
</div>

<!-- Features grid -->
<section class="sec">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Что включено</span></div>
  <h2 class="title fade" style="margin-bottom:32px;">Возможности</h2>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
    {service.features.map(f => (
      <div class="card fade">
        <div class="card-icon"><Fragment set:html={IC[f.iconKey]} /></div>
        <div class="card-title" style="margin-bottom:8px;">{f.title}</div>
        <div class="card-desc">{f.desc}</div>
      </div>
    ))}
  </div>
</section>

<!-- Stats -->
<section class="sec" style="background:var(--dark2);">
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;text-align:center;">
    {service.stats.map(([val, label]) => (
      <div class="card fade">
        <div class="stat-n" style="font-size:2rem;font-weight:700;color:var(--gold);">{val}</div>
        <div class="stat-l" style="color:var(--gray);font-size:12px;margin-top:4px;">{label}</div>
      </div>
    ))}
  </div>
</section>

<!-- SEO text -->
<section class="sec">
  <div class="two-col">
    <div class="fade">
      <div class="sec-label"><div class="sec-label-line"></div><span class="sec-label-text">{service.seoTitle}</span></div>
      <h2 class="title" style="margin-bottom:24px;">{service.title}<br>по Казахстану</h2>
      {service.seoText.map(para => (
        <p class="desc" style="margin-bottom:16px;">{para}</p>
      ))}
      <a class="btn btn-outline" href="/kontakty" style="margin-top:8px;">Оставить заявку <Fragment set:html={ARR} /></a>
    </div>
    <div class="fade" style="display:flex;flex-direction:column;gap:16px;justify-content:center;">
      <div class="card" style="text-align:center;padding:32px;">
        <div class="card-icon" style="margin:0 auto 16px;"><Fragment set:html={IC[service.iconKey]} /></div>
        <div class="card-title" style="margin-bottom:12px;">{service.title}</div>
        <p class="card-desc" style="margin-bottom:20px;">Нужна консультация или расчёт стоимости?</p>
        <a class="btn btn-gold" href={`tel:${SITE_PHONE.replace(/\s/g,'')}`} style="width:100%;justify-content:center;">{SITE_PHONE}</a>
      </div>
    </div>
  </div>
</section>

<!-- Related services -->
<section class="sec" style="background:var(--dark2);">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Смотрите также</span></div>
  <h2 class="title fade" style="margin-bottom:32px;">Похожие услуги</h2>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
    {service.related.map(([iconKey, title, path]) => (
      <a class="card card-link fade" href={path}>
        <div class="card-icon"><Fragment set:html={IC[iconKey]} /></div>
        <div class="card-title">{title}</div>
        <div class="card-arr"><Fragment set:html={ARR} /></div>
      </a>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="sec" style="text-align:center;">
  <div class="fade">
    <div class="sec-label" style="justify-content:center;"><div class="sec-label-line"></div><span class="sec-label-text">Начните прямо сейчас</span><div class="sec-label-line"></div></div>
    <h2 class="title" style="margin-bottom:16px;">Нужна перевозка?</h2>
    <p class="desc" style="max-width:500px;margin:0 auto 28px;">Оставьте заявку — менеджер свяжется в течение 30 минут и рассчитает стоимость доставки</p>
    <a class="btn btn-gold" href="/kontakty" style="font-size:13px;padding:16px 40px;"><Fragment set:html={ARR} /> Оставить заявку</a>
  </div>
</section>

</Layout>

---
import Layout from '../layouts/Layout.astro';
import { ARR } from '../data/icons.js';

const SITE_PHONE = '+7 775 242 77 44';
const SITE_URL = 'https://ontimeservice.kz';

const FAQ_GROUPS = [
  {
    title: 'О компании',
    items: [
      {q:'Сколько лет On Time Service на рынке?', a:'Работаем с 2005 года — более 20 лет. За это время выполнили тысячи перевозок по Казахстану, России, Китаю и СНГ.'},
      {q:'Где находится ваш офис?', a:'Главный офис в Алматы, Казахстан. Работаем по всем регионам страны и международным направлениям.'},
      {q:'Какие виды перевозок вы выполняете?', a:'Автоперевозки FTL и LTL, негабаритные грузы, перевозка тралом, сборные грузы, доставка из Китая, международные перевозки в Россию и СНГ, доставка по Алматы.'},
      {q:'Работаете ли вы с физическими лицами?', a:'Да, работаем как с юридическими, так и с физическими лицами. Договор и закрывающие документы оформляем для всех клиентов.'},
    ],
  },
  {
    title: 'Расчёт и заказ',
    items: [
      {q:'Сколько стоит грузоперевозка?', a:'Стоимость зависит от шести факторов: расстояние, вес, объём, тип груза, тип транспорта, срочность. Базовая стоимость рейса Алматы — Астана: от 180 000 ₸ (газель) или от 350 000 ₸ (фура).'},
      {q:'Как быстро вы рассчитываете стоимость?', a:'В течение 30 минут после получения заявки. В рабочее время обычно 5-15 минут.'},
      {q:'Можно ли заказать перевозку онлайн?', a:'Да. Заполните форму заявки на странице «Контакты» или напишите в WhatsApp. Менеджер свяжется и оформит заказ.'},
      {q:'Какой минимальный вес груза вы принимаете?', a:'От 100 кг — отправляем сборными грузами LTL. Меньшие партии возможны по индивидуальной договорённости.'},
      {q:'Вы работаете в выходные?', a:'Менеджеры принимают заявки 7 дней в неделю с 9:00 до 21:00. Срочные перевозки оформляем в любое время.'},
    ],
  },
  {
    title: 'Сроки и доставка',
    items: [
      {q:'Сколько идёт груз из Алматы в Астану?', a:'Стандартный срок 1-2 дня. Время в пути для грузового транспорта 14-16 часов с учётом обязательных остановок водителя.'},
      {q:'Сколько идёт груз из Китая?', a:'Через Хоргос автотранспортом — 12-18 дней до Алматы. Железнодорожной доставкой — 10-14 дней. Авиа — 3-5 дней (для срочных и дорогостоящих грузов).'},
      {q:'Сколько идёт груз в Москву?', a:'Автотранспортом 5-7 дней (4600 км). Железнодорожной доставкой 10-14 дней. Без таможенных пошлин — обе страны в ЕАЭС.'},
      {q:'Можете ли вы доставить срочно?', a:'Да, организуем экспресс-доставку. Стоимость на 30-50% выше стандартной, но сроки сокращаются на 30-40%.'},
    ],
  },
  {
    title: 'Транспорт и груз',
    items: [
      {q:'Какой максимальный вес груза вы перевозите?', a:'Стандартная фура (еврофура) — до 20 тонн. Тяжёловозный трал — до 70 тонн. Для негабарита оформляем разрешение и согласование маршрута.'},
      {q:'Перевозите ли вы скоропортящиеся грузы?', a:'Да, в нашем парке есть рефрижераторы с поддержанием температурного режима от -20°C до +20°C.'},
      {q:'Что считается негабаритным грузом?', a:'Превышение по любому параметру: длина более 20 м, ширина более 2,55 м, высота более 4 м, вес более 40 тонн. Требуется специальное разрешение.'},
      {q:'Перевозите ли опасные грузы?', a:'Да, у нас есть водители с допуском ADR. Требуется паспорт безопасности груза, аварийная карточка, согласование маршрута.'},
    ],
  },
  {
    title: 'Документы и таможня',
    items: [
      {q:'Какие документы вы выдаёте?', a:'Договор, ТТН/CMR, заявка, акт приёма-передачи, счёт-фактура, акт выполненных работ. Полный пакет для бухгалтерского учёта. Подробнее на странице "Документы".'},
      {q:'Помогаете ли с таможенным оформлением?', a:'Да, сотрудничаем с аккредитованными таможенными брокерами. Берём на себя оформление при импорте из Китая, Турции, Ирана и других третьих стран.'},
      {q:'Нужна ли таможня для перевозок Казахстан-Россия?', a:'Нет таможенных пошлин — обе страны в ЕАЭС. Сохраняется пограничный, ветеринарный и санитарный контроль. Документы: CMR, инвойс, упаковочный лист.'},
      {q:'Какие документы нужны для отправки в Узбекистан?', a:'CMR, инвойс, упаковочный лист, контракт с получателем, сертификаты соответствия (для отдельных категорий товаров). Узбекистан не в ЕАЭС — требуется полное таможенное оформление.'},
    ],
  },
  {
    title: 'Безопасность и страхование',
    items: [
      {q:'Страхуете ли вы груз?', a:'Базовая ответственность перевозчика согласно законодательству включена в стоимость. Расширенное страхование на полную стоимость груза — отдельная услуга, обычно 0,1-0,3% от стоимости.'},
      {q:'Что делать если груз повредили?', a:'При выявлении повреждений на момент выгрузки — составляется акт с описанием. Это основание для претензии. Если оформлено страхование — выплата производится страховой компанией.'},
      {q:'Как отслеживать груз?', a:'Менеджер сообщает статус по запросу. На многих машинах установлены GPS-трекеры. По крупным заказам предоставляем доступ к онлайн-отслеживанию.'},
      {q:'Что если груз задерживается?', a:'В договоре прописана ответственность за просрочку. Стандартно — 0,1% от стоимости перевозки за каждый день, но не более 50% от общей суммы. Форс-мажор (стихийные бедствия, погранзакрытия) исключения.'},
    ],
  },
];

const allFaqItems = FAQ_GROUPS.flatMap(g => g.items);

const voprosySchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Главная", "item": `${SITE_URL}/`},
        {"@type": "ListItem", "position": 2, "name": "Вопросы и ответы", "item": `${SITE_URL}/voprosy-otvety`}
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": allFaqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {"@type": "Answer", "text": item.a}
      }))
    }
  ]
};
---
<Layout
  title="Вопросы и ответы — On Time Service | Грузоперевозки по Казахстану"
  description={`Ответы на частые вопросы о грузоперевозках: сроки, цены, документы, страхование, таможня. ✓ 25+ ответов от экспертов On Time Service. Тел: ${SITE_PHONE}`}
  canonical="/voprosy-otvety"
  schema={voprosySchema}
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><span class="current">Вопросы и ответы</span>
</div>

<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">FAQ</span></div>
  <h1 class="title anim-2">Вопросы<br>и ответы</h1>
  <p class="desc anim-3" style="max-width:640px;">{allFaqItems.length} ответов на самые частые вопросы про грузоперевозки. Если не нашли свой — позвоните или напишите в WhatsApp, ответим в течение 30 минут.</p>
</div>

{FAQ_GROUPS.map((group, gi) => (
  <section class="sec" style={gi % 2 === 1 ? 'background:var(--dark2);' : ''}>
    <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Раздел {gi + 1}</span></div>
    <h2 class="title fade" style="margin-bottom:32px;">{group.title}</h2>
    <div style="display:flex;flex-direction:column;gap:12px;max-width:900px;">
      {group.items.map(({q,a}) => (
        <details class="card fade" style="cursor:pointer;padding:0;overflow:hidden;">
          <summary style="padding:20px 24px;font-size:15px;font-weight:600;color:var(--text);list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;">
            <span>{q}</span>
            <span style="color:var(--gold);font-size:20px;flex-shrink:0;">+</span>
          </summary>
          <div style="padding:0 24px 20px;color:var(--text2);font-size:14px;line-height:1.7;">{a}</div>
        </details>
      ))}
    </div>
  </section>
))}

<section class="sec" style="text-align:center;">
  <div class="fade">
    <div class="sec-label" style="justify-content:center;"><div class="sec-label-line"></div><span class="sec-label-text">Не нашли ответ?</span><div class="sec-label-line"></div></div>
    <h2 class="title" style="margin-bottom:16px;">Спросите нас</h2>
    <p class="desc" style="max-width:520px;margin:0 auto 28px;">Менеджер ответит в течение 30 минут — звоните, пишите в WhatsApp или оставьте заявку на сайте.</p>
    <a class="btn btn-gold" href="/kontakty" style="font-size:13px;padding:16px 40px;"><Fragment set:html={ARR} /> Связаться</a>
  </div>
</section>

</Layout>

---
import Layout from '../layouts/Layout.astro';
import { IC, ARR } from '../data/icons.js';

const SITE_PHONE = '+7 775 242 77 44';
const SITE_URL = 'https://ontimeservice.kz';

const oLogistikeSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Главная", "item": `${SITE_URL}/`},
    {"@type": "ListItem", "position": 2, "name": "О логистике", "item": `${SITE_URL}/o-logistike`}
  ]
};
---
<Layout
  title="О логистике в Казахстане — On Time Service | Транспортная система РК"
  description={`Транспортная логистика Казахстана: виды перевозок, инфраструктура, особенности рынка. Информация от экспертов On Time Service. Тел: ${SITE_PHONE}`}
  canonical="/o-logistike"
  schema={oLogistikeSchema}
>

<div class="breadcrumb">
  <a href="/">Главная</a><span class="sep"> / </span><span class="current">О логистике</span>
</div>
<div class="page-header">
  <div class="sec-label anim-1"><div class="sec-label-line"></div><span class="sec-label-text">Экспертные материалы</span></div>
  <h1 class="title anim-2">О логистике<br>в Казахстане</h1>
  <p class="desc anim-3" style="max-width:600px;">Транспортная система Казахстана, виды грузоперевозок, особенности рынка и практические советы для грузоотправителей.</p>
</div>

<!-- Overview -->
<section class="sec">
  <div class="two-col">
    <div class="fade">
      <div class="sec-label"><div class="sec-label-line"></div><span class="sec-label-text">Транспортный комплекс РК</span></div>
      <h2 class="title" style="margin-bottom:20px;">Логистика<br>Казахстана</h2>
      <p class="desc" style="margin-bottom:16px;">Казахстан — крупнейшая страна СНГ (9-е место в мире по площади, 2725 тыс. км²). Развитие транспортно-коммуникационного комплекса является приоритетом государственной политики.</p>
      <p class="desc" style="margin-bottom:16px;">Страна занимает стратегическое положение на пересечении торговых путей между Европой, Россией и Азией. Коридоры «Шёлковый путь» и «Средний коридор» проходят через Казахстан.</p>
      <p class="desc">Автомобильный транспорт обеспечивает около 60% всех внутренних грузоперевозок. Ключевые автодороги: Западная Европа — Западный Китай, CAREC и другие.</p>
    </div>
    <div class="fade" style="display:flex;flex-direction:column;gap:16px;">
      {[
        {iconKey:'truck', title:'Автомобильный транспорт', desc:'~60% внутренних перевозок. Основной вид доставки «от двери до двери».'},
        {iconKey:'road', title:'Железная дорога', desc:'~38% грузооборота. Уголь, руда, зерно, нефтепродукты.'},
        {iconKey:'ship', title:'Морской транспорт', desc:'Каспийское море. Актауский порт — выход на Азербайджан и Иран.'},
        {iconKey:'plan', title:'Авиалогистика', desc:'Срочные и ценные грузы. Алматы — крупнейший авиахаб региона.'},
      ].map(({iconKey, title, desc}) => (
        <div class="card" style="display:flex;align-items:flex-start;gap:14px;padding:16px 20px;">
          <div style="flex-shrink:0;width:36px;height:36px;color:var(--gold);"><Fragment set:html={IC[iconKey]} /></div>
          <div>
            <div style="color:var(--light);font-weight:600;margin-bottom:4px;font-size:14px;">{title}</div>
            <div style="color:var(--gray);font-size:13px;">{desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Types of cargo -->
<section class="sec" style="background:var(--dark2);">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Классификация</span></div>
  <h2 class="title fade" style="margin-bottom:32px;">Виды грузов<br>и перевозок</h2>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
    {[
      {iconKey:'box', title:'FTL (Full Truckload)', desc:'Полная загрузка — выделенный автомобиль под один груз. Прямая доставка без перегрузок.'},
      {iconKey:'box', title:'LTL (Less than Truckload)', desc:'Сборные грузы — консолидация нескольких отправителей в одну машину. Экономия до 60%.'},
      {iconKey:'oversize', title:'Негабаритные грузы', desc:'Грузы, превышающие стандартные габариты: длина >20м, ширина >2.55м, высота >4м.'},
      {iconKey:'lowboy', title:'Тяжеловозные перевозки', desc:'Грузы весом свыше 20 тонн. Спецтранспорт (трал, низкорамный прицеп).'},
      {iconKey:'warehouse', title:'Рефрижераторные', desc:'Температурные грузы: продукты, медикаменты, химия. Диапазон от -25 до +12°С.'},
      {iconKey:'ship', title:'Мультимодальные', desc:'Комбинация авто + ж/д + море. Оптимально для международных маршрутов.'},
    ].map(({iconKey, title, desc}) => (
      <div class="card fade">
        <div class="card-icon"><Fragment set:html={IC[iconKey]} /></div>
        <div class="card-title" style="margin-bottom:8px;">{title}</div>
        <div class="card-desc">{desc}</div>
      </div>
    ))}
  </div>
</section>

<!-- Useful links -->
<section class="sec">
  <div class="sec-label fade"><div class="sec-label-line"></div><span class="sec-label-text">Полезные ссылки</span></div>
  <h2 class="title fade" style="margin-bottom:32px;">Наши услуги</h2>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;">
    {[
      {iconKey:'truck', title:'Автоперевозки FTL и LTL', path:'/uslugi/avtoperevozki'},
      {iconKey:'oversize', title:'Негабаритные грузы', path:'/uslugi/negabarit'},
      {iconKey:'lowboy', title:'Перевозка тралом', path:'/uslugi/tral'},
      {iconKey:'ship', title:'Грузы из Китая', path:'/uslugi/kitay'},
      {iconKey:'globe', title:'Россия и СНГ', path:'/uslugi/rossiya-sng'},
      {iconKey:'map', title:'По всему Казахстану', path:'/uslugi/po-kazakhstanu'},
    ].map(({iconKey, title, path}) => (
      <a class="card card-link fade" href={path} style="display:flex;align-items:center;gap:14px;padding:16px 20px;">
        <div style="flex-shrink:0;width:36px;height:36px;color:var(--gold);"><Fragment set:html={IC[iconKey]} /></div>
        <div style="color:var(--light);font-weight:500;font-size:14px;">{title}</div>
        <div style="margin-left:auto;color:var(--gold);width:20px;height:20px;"><Fragment set:html={ARR} /></div>
      </a>
    ))}
  </div>
</section>

</Layout>

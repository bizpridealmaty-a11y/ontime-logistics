---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  keywords?: string;
  heroImageSrcset?: string;
  heroImageSizes?: string;
}

const { title, description, canonical = Astro.url.pathname, schema, keywords, heroImageSrcset, heroImageSizes } = Astro.props;
const SITE_URL = 'https://ontimeservice.kz';
const SITE_PHONE = '+7 775 242 77 44';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MovingCompany"],
  "@id": `${SITE_URL}/#organization`,
  "name": "On Time Service",
  "alternateName": "Он Тайм Сервис",
  "description": "Транспортная компания. Грузоперевозки по Алматы, Астане и всему Казахстану. Автоперевозки, негабаритные грузы, перевозки из Китая.",
  "url": `${SITE_URL}/`,
  "telephone": "+77752427744",
  "email": "info@ontimeservice.kz",
  "foundingDate": "2005",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "г. Алматы",
    "addressLocality": "Алматы",
    "addressRegion": "Алматинская область",
    "addressCountry": "KZ",
    "postalCode": "050000"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.238949,
    "longitude": 76.889709
  },
  "areaServed": [
    {"@type": "City", "name": "Алматы"},
    {"@type": "City", "name": "Астана"},
    {"@type": "City", "name": "Шымкент"},
    {"@type": "City", "name": "Карагандa"},
    {"@type": "City", "name": "Атырау"},
    {"@type": "City", "name": "Актау"},
    {"@type": "City", "name": "Костанай"},
    {"@type": "City", "name": "Павлодар"},
    {"@type": "City", "name": "Усть-Каменогорск"},
    {"@type": "City", "name": "Тараз"},
    {"@type": "City", "name": "Актобе"},
    {"@type": "City", "name": "Семей"},
    {"@type": "AdministrativeArea", "name": "Алматинская область"},
    {"@type": "Country", "name": "Казахстан"},
    {"@type": "Country", "name": "Россия"},
    {"@type": "Country", "name": "Китай"}
  ],
  "serviceType": ["Грузоперевозки", "Автоперевозки FTL", "Автоперевозки LTL", "Негабаритные перевозки", "Перевозка тралом", "Сборные грузы", "Доставка грузов из Китая", "Международные грузоперевозки", "жүк тасымалдау"],
  "slogan": "Надёжное звено в сфере транспортной логистики",
  "numberOfEmployees": {"@type": "QuantitativeValue", "minValue": 10},
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+77752427744",
    "contactType": "customer service",
    "areaServed": "KZ",
    "availableLanguage": ["Russian", "Kazakh"]
  },
  "sameAs": [
    "https://github.com/bizpridealmaty-a11y/ontime-logistics"
  ]
};

const canonicalUrl = `${SITE_URL}${canonical === '/' ? '/' : canonical}`;
---
<!DOCTYPE html>
<html lang="ru" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  {keywords && <meta name="keywords" content={keywords}>}
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <meta name="author" content="On Time Service">
  <link rel="canonical" href={canonicalUrl}>

  <!-- GEO TAGS -->
  <meta name="geo.region" content="KZ-ALA">
  <meta name="geo.placename" content="Алматы, Казахстан">
  <meta name="geo.position" content="43.238949;76.889709">
  <meta name="ICBM" content="43.238949, 76.889709">
  <meta name="DC.title" content="Грузоперевозки Алматы | On Time Service">

  <!-- OPEN GRAPH -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:locale" content="ru_KZ">
  <meta property="og:site_name" content="On Time Service">

  <!-- Schema.org Organization (global) -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Preconnect to image CDN -->
  <link rel="preconnect" href="https://images.unsplash.com" crossorigin>
  <link rel="dns-prefetch" href="https://images.unsplash.com">

  {heroImageSrcset && (
    <link rel="preload" as="image" imagesrcset={heroImageSrcset} imagesizes={heroImageSizes ?? '100vw'} />
  )}

  <!-- Self-hosted fonts (Manrope variable + Bebas Neue). Same-origin = no extra DNS/TLS handshake. -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/manrope-cyrillic.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/manrope-latin.woff2" crossorigin>
  <link rel="stylesheet" href="/fonts/fonts.css">

  <!-- Analytics (prod only) -->
  <Analytics />
</head>
<body>

